# Core demo config
PORT=8000
APP_MODE=demo
CREATOR_HANDLE=@lexfridman

# Redis - local Docker recommended:
# docker run -d -p 6379:6379 --name faniq-redis redis:alpine
REDIS_URL=redis://localhost:6379

# Redis Cloud option. Prefer REDIS_URL if you already have one:
# REDIS_URL=redis://default:YOUR_PASSWORD@redis-10864.c13.us-east-1-3.ec2.cloud.redislabs.com:10864
# If TLS is required by the database, use rediss:// instead of redis://.
# Or use discrete vars; the app will build REDIS_URL from these if REDIS_URL is empty.
REDIS_HOST=
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=
REDIS_SSL=false

# TinyFish - optional for live path; demo mode works without it
TINYFISH_API_KEY=
TINYFISH_BASE_URL=https://agent.tinyfish.ai/v1

# Vapi - optional dashboard integration; /vapi/llm works locally without these
VAPI_API_KEY=
VAPI_ASSISTANT_A_ID=
NGROK_URL=

# Optional LLM enhancement; deterministic fallback works without this
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Optional sponsor depth
SENSO_API_KEY=
SENSO_API_URL=
GHOST_API_URL=
GHOST_ADMIN_API_KEY=

# Ghost Build / MCP is installed manually:
# curl -fsSL https://install.ghost.build/ | sh
# ghost login
# ghost mcp install
GHOST_BUILD_ENABLED=false
